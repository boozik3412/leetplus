# Copy to /etc/leetplus/telegram-edge.env on the non-RF Telegram edge VDS.
# Keep real tokens only on the server.

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Public edge domain used by Telegram BotFather / webhook / Mini App.
TG_EDGE_PUBLIC_ORIGIN=https://tg.leetplus.example

# Main LeetPlus API is still the source of business truth. Point this to the
# HTTPS proxy/tunnel endpoint if the edge VDS should not connect directly.
API_URL=https://api.leetplus.ru
NEXT_PUBLIC_API_URL=https://api.leetplus.ru
GUEST_GAME_TG_EDGE_LEETPLUS_API_URL=https://api.leetplus.ru
GUEST_GAME_TG_EDGE_LEETPLUS_WEBHOOK_PATH=/guest-portal/telegram/webhook

# Telegram webhook adapter.
GUEST_GAME_TG_EDGE_HOST=127.0.0.1
GUEST_GAME_TG_EDGE_PORT=4010
GUEST_GAME_TG_EDGE_WEBHOOK_SECRET=
GUEST_GAME_TG_EDGE_BOT_TOKEN=
GUEST_GAME_TG_EDGE_DRY_RUN=true
GUEST_GAME_TG_EDGE_REQUEST_TIMEOUT_MS=15000
GUEST_GAME_TG_EDGE_HEALTH_SECRET=
GUEST_GAME_TG_EDGE_SHARED_SECRET=

# Default direct Bot API. If traffic must go through an application proxy,
# set this to the proxy base URL that preserves /bot<TOKEN>/<method>.
GUEST_GAME_TG_EDGE_TELEGRAM_API_BASE_URL=https://api.telegram.org

# Mini App web process. Nginx exposes only /game/app, /_next/* and
# /api/guest-portal/* from this local Next process.
TG_EDGE_WEB_HOST=127.0.0.1
TG_EDGE_WEB_PORT=3100

# Optional outbox runner for ready reward deliveries on the same edge VDS.
GUEST_GAME_BOT_CONSUMER_API_URL=https://api.leetplus.ru
# Copy from the main LeetPlus API env: SYNC_SERVICE_TOKEN. Do not take it from
# Langame/1337.
GUEST_GAME_BOT_CONSUMER_SYNC_TOKEN=
# Copy from the main LeetPlus database, table "Tenant" (usually Tenant.slug).
GUEST_GAME_BOT_CONSUMER_TENANT_SLUG=
GUEST_GAME_BOT_CONSUMER_CHANNELS=TELEGRAM
GUEST_GAME_BOT_CONSUMER_LIMIT=10
GUEST_GAME_BOT_CONSUMER_DRY_RUN=true
GUEST_GAME_BOT_CONSUMER_INTERVAL_MS=
GUEST_GAME_BOT_CONSUMER_MAX_TICKS=1
GUEST_GAME_BOT_CONSUMER_REQUEST_TIMEOUT_MS=15000
GUEST_GAME_BOT_CONSUMER_TELEGRAM_BOT_TOKEN=
GUEST_GAME_BOT_CONSUMER_TELEGRAM_API_BASE_URL=https://api.telegram.org
