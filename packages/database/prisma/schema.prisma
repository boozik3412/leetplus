generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  BUYER
  ADMIN
}

enum StockMovementType {
  WRITEOFF
  RETURN
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  stores    Store[]
  suppliers Supplier[]
  products  Product[]
  categories Category[]
  importJobs ImportJob[]
  salesFacts SalesFact[]
  inventorySnapshots InventorySnapshot[]
  stockMovements StockMovement[]
}

model User {
  id              String    @id @default(uuid())
  tenantId        String
  email           String    @unique
  passwordHash    String
  fullName        String?
  role            UserRole  @default(OWNER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  emailVerificationTokens EmailVerificationToken[]
  importJobs              ImportJob[]

  @@index([tenantId])
}

model ImportJob {
  id             String   @id @default(uuid())
  tenantId       String
  userId         String?
  type           String
  sourceFileName String?
  status         String
  totalRows      Int      @default(0)
  validRows      Int      @default(0)
  importedRows   Int      @default(0)
  errorsCount    Int      @default(0)
  errorSummary   Json?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId])
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Store {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  salesFacts SalesFact[]
  inventorySnapshots InventorySnapshot[]
  stockMovements StockMovement[]

  @@index([tenantId])
}

model Category {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Supplier {
  id                String   @id @default(uuid())
  tenantId          String
  name              String
  paymentDelayDays  Int?
  minOrderAmount    Decimal?
  orderMultiplicity Int?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id            String   @id @default(uuid())
  tenantId      String
  categoryId    String?
  supplierId    String?
  article       String
  name          String
  purchasePrice Decimal
  salePrice     Decimal
  facing        Int      @default(1)
  shelfLifeDays Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  salesFacts SalesFact[]
  inventorySnapshots InventorySnapshot[]
  stockMovements StockMovement[]

  @@unique([tenantId, article])
  @@index([tenantId])
  @@index([categoryId])
  @@index([supplierId])
}

model SalesFact {
  id        String   @id @default(uuid())
  tenantId  String
  storeId   String
  productId String
  saleDate  DateTime
  quantity  Decimal
  revenue   Decimal
  cost      Decimal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, storeId, productId, saleDate])
  @@index([tenantId, saleDate])
  @@index([storeId])
  @@index([productId])
}

model InventorySnapshot {
  id           String   @id @default(uuid())
  tenantId     String
  storeId      String
  productId    String
  snapshotDate DateTime
  quantity     Decimal
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, storeId, productId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@index([storeId])
  @@index([productId])
}

model StockMovement {
  id           String            @id @default(uuid())
  tenantId     String
  storeId      String
  productId    String
  movementDate DateTime
  type         StockMovementType
  quantity     Decimal
  amount       Decimal
  reason       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, storeId, productId, movementDate, type])
  @@index([tenantId, movementDate])
  @@index([storeId])
  @@index([productId])
  @@index([type])
}