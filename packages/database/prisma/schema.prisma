generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  BUYER
  ADMIN
  MARKETER
  CLUB_MANAGER
  STANDARDS_MANAGER
  SENIOR_ADMINISTRATOR
  CLUB_ADMINISTRATOR
}

enum StockMovementType {
  WRITEOFF
  RETURN
}

enum IntegrationProvider {
  LANGAME
}

enum IntegrationSyncStatus {
  SUCCESS
  FAILED
}

enum IntegrationSyncTrigger {
  MANUAL
  AUTO
}

enum IntegrationSyncMode {
  QUICK
  INVENTORY
  CATALOG
  BACKFILL
  FULL
}

enum ProductParsingSuggestionStatus {
  PENDING
  APPLIED
  REJECTED
}

enum ProductOosExclusionType {
  SERVICE
  OOS_EXCLUDED
}

enum ProductAssortmentRole {
  CORE
  TRAFFIC_DRIVER
  MARGIN_DRIVER
  IMPULSE
  SEASONAL
  TEST
  SERVICE
  OPTIONAL
  EXCLUDED
}

enum RecommendationStatus {
  NEW
  IN_PROGRESS
  DONE
  REJECTED
  HIDDEN
  REAPPEARED
}

enum RecommendationRole {
  COMMERCIAL_DIRECTOR
  BUYER
  CLUB_MANAGER
}

enum GuestCrmStatus {
  NONE
  WATCH
  CONTACT
  INVITED
  LOYAL
  VIP
  PROBLEM
  DO_NOT_CONTACT
}

enum GuestCommunicationConsentStatus {
  UNKNOWN
  GRANTED
  DENIED
  UNSUBSCRIBED
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                                User[]
  stores                               Store[]
  suppliers                            Supplier[]
  products                             Product[]
  canonicalProducts                    CanonicalProduct[]
  productParsingRuns                   ProductParsingRun[]
  productParsingSuggestions            ProductParsingSuggestion[]
  productOosExclusions                 ProductOosExclusion[]
  categories                           Category[]
  importJobs                           ImportJob[]
  salesFacts                           SalesFact[]
  clubRevenueFacts                     ClubRevenueFact[]
  inventorySnapshots                   InventorySnapshot[]
  stockMovements                       StockMovement[]
  integrationCredentials               IntegrationCredential[]
  integrationSources                   IntegrationSource[]
  integrationSyncJobs                  IntegrationSyncJob[]
  guests                               Guest[]
  guestGroups                          GuestGroup[]
  guestBalanceSnapshots                GuestBalanceSnapshot[]
  guestBonusBalanceSnapshots           GuestBonusBalanceSnapshot[]
  guestSessions                        GuestSession[]
  guestLogs                            GuestLog[]
  guestTransactions                    GuestTransaction[]
  guestOperationLogs                   GuestOperationLog[]
  guestWorkingShifts                   GuestWorkingShift[]
  guestDataProfileRuns                 GuestDataProfileRun[]
  guestCrmEvents                       GuestCrmEvent[]
  guestCrmLeads                        GuestCrmLead[]
  guestCrmTasks                        GuestCrmTask[]
  guestCrmContactEvents                GuestCrmContactEvent[]
  marketingCampaigns                   MarketingCampaign[]
  marketingPromoBundles                MarketingPromoBundle[]
  marketingPromoBundleLaunches         MarketingPromoBundleLaunch[]
  marketingPromoBundleUsages           MarketingPromoBundleUsage[]
  recommendationStates                 RecommendationState[]
  reportDigestScheduleRuns             ReportDigestScheduleRun[]
  guestStaffIdentityMappings           GuestStaffIdentityMapping[]
  staffTasks                           StaffTask[]
  staffTaskTemplates                   StaffTaskTemplate[]
  staffTaskComments                    StaffTaskComment[]
  staffTaskAuditEvents                 StaffTaskAuditEvent[]
  staffKnowledgeArticles               StaffKnowledgeArticle[]
  staffKnowledgeArticleVersions        StaffKnowledgeArticleVersion[]
  staffTrainingCourses                 StaffTrainingCourse[]
  staffTrainingProgresses              StaffTrainingProgress[]
  staffOnboardingPlans                 StaffOnboardingPlan[]
  staffAssessments                     StaffAssessment[]
  staffAssessmentResults               StaffAssessmentResult[]
  staffShiftRegulations                StaffShiftRegulation[]
  staffShiftRegulationVersions         StaffShiftRegulationVersion[]
  staffShiftRegulationAcknowledgements StaffShiftRegulationAcknowledgement[]
  staffChecklistTemplates              StaffChecklistTemplate[]
  staffChecklistRuns                   StaffChecklistRun[]
  staffAttachments                     StaffAttachment[]
  staffDisciplinePolicies              StaffDisciplinePolicy[]
  staffDisciplineRules                 StaffDisciplineRule[]
  staffDisciplineRecords               StaffDisciplineRecord[]
  staffSalarySchemes                    StaffSalaryScheme[]
  staffChatChannels                    StaffChatChannel[]
  staffChatChannelMembers              StaffChatChannelMember[]
  staffChatMessages                    StaffChatMessage[]
  staffChatReadReceipts                StaffChatReadReceipt[]
  guestSavedFilters                    GuestSavedFilter[]
  guestAudiences                       GuestAudience[]
  guestAudienceMembers                 GuestAudienceMember[]
  userAccessRoles                      UserAccessRole[]
  userInvites                          UserInvite[]
}

model User {
  id              String    @id @default(uuid())
  tenantId        String
  email           String    @unique
  passwordHash    String
  fullName        String?
  role            UserRole  @default(OWNER)
  customRoleId    String?
  isActive        Boolean   @default(true)
  isPlatformAdmin Boolean   @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant                               Tenant                                @relation(fields: [tenantId], references: [id])
  customRole                           UserAccessRole?                       @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  emailVerificationTokens              EmailVerificationToken[]
  importJobs                           ImportJob[]
  guestCrmEvents                       GuestCrmEvent[]
  guestCrmLeads                        GuestCrmLead[]
  guestCrmTasks                        GuestCrmTask[]                        @relation("GuestCrmTaskCreatedBy")
  assignedGuestCrmTasks                GuestCrmTask[]                        @relation("GuestCrmTaskAssignedTo")
  guestCrmContactEvents                GuestCrmContactEvent[]
  createdMarketingCampaigns            MarketingCampaign[]                   @relation("MarketingCampaignCreatedBy")
  ownedMarketingCampaigns              MarketingCampaign[]                   @relation("MarketingCampaignOwner")
  createdMarketingPromoBundles         MarketingPromoBundle[]                @relation("MarketingPromoBundleCreatedBy")
  createdMarketingPromoBundleLaunches  MarketingPromoBundleLaunch[]          @relation("MarketingPromoBundleLaunchCreatedBy")
  createdMarketingPromoBundleUsages    MarketingPromoBundleUsage[]           @relation("MarketingPromoBundleUsageCreatedBy")
  guestStaffIdentityMappings           GuestStaffIdentityMapping[]
  createdStaffTasks                    StaffTask[]                           @relation("StaffTaskCreatedBy")
  createdStaffTaskTemplates            StaffTaskTemplate[]                   @relation("StaffTaskTemplateCreatedBy")
  assignedStaffTasks                   StaffTask[]                           @relation("StaffTaskAssignedTo")
  staffTaskComments                    StaffTaskComment[]                    @relation("StaffTaskCommentAuthor")
  staffTaskAuditEvents                 StaffTaskAuditEvent[]                 @relation("StaffTaskAuditActor")
  createdStaffKnowledgeArticles        StaffKnowledgeArticle[]               @relation("StaffKnowledgeArticleCreatedBy")
  approvedStaffKnowledgeArticles       StaffKnowledgeArticle[]               @relation("StaffKnowledgeArticleApprovedBy")
  createdStaffKnowledgeArticleVersions StaffKnowledgeArticleVersion[]         @relation("StaffKnowledgeArticleVersionCreatedBy")
  createdStaffTrainingCourses          StaffTrainingCourse[]                 @relation("StaffTrainingCourseCreatedBy")
  staffTrainingProgresses              StaffTrainingProgress[]               @relation("StaffTrainingProgressUser")
  updatedStaffTrainingProgresses       StaffTrainingProgress[]               @relation("StaffTrainingProgressUpdatedBy")
  createdStaffOnboardingPlans          StaffOnboardingPlan[]                 @relation("StaffOnboardingPlanCreatedBy")
  createdStaffAssessments              StaffAssessment[]                     @relation("StaffAssessmentCreatedBy")
  staffAssessmentResults               StaffAssessmentResult[]               @relation("StaffAssessmentUser")
  reviewedStaffAssessmentResults       StaffAssessmentResult[]               @relation("StaffAssessmentReviewedBy")
  createdStaffShiftRegulations         StaffShiftRegulation[]                @relation("StaffShiftRegulationCreatedBy")
  createdStaffShiftRegulationVersions  StaffShiftRegulationVersion[]         @relation("StaffShiftRegulationVersionCreatedBy")
  staffShiftRegulationAcknowledgements StaffShiftRegulationAcknowledgement[]
  createdStaffChecklistTemplates       StaffChecklistTemplate[]              @relation("StaffChecklistTemplateCreatedBy")
  createdStaffChecklistRuns            StaffChecklistRun[]                   @relation("StaffChecklistRunCreatedBy")
  assignedStaffChecklistRuns           StaffChecklistRun[]                   @relation("StaffChecklistRunAssignedTo")
  reviewedStaffChecklistRuns           StaffChecklistRun[]                   @relation("StaffChecklistRunReviewedBy")
  updatedStaffDisciplinePolicies       StaffDisciplinePolicy[]               @relation("StaffDisciplinePolicyUpdatedBy")
  createdStaffDisciplineRules          StaffDisciplineRule[]                 @relation("StaffDisciplineRuleCreatedBy")
  staffDisciplineRecords               StaffDisciplineRecord[]               @relation("StaffDisciplineRecordUser")
  createdStaffDisciplineRecords        StaffDisciplineRecord[]               @relation("StaffDisciplineRecordCreatedBy")
  createdStaffSalarySchemes            StaffSalaryScheme[]                   @relation("StaffSalarySchemeCreatedBy")
  guestSavedFilters                    GuestSavedFilter[]
  guestAudiences                       GuestAudience[]
  storeAccesses                        UserStoreAccess[]
  createdUserInvites                   UserInvite[]                          @relation("UserInviteCreatedBy")
  acceptedUserInvites                  UserInvite[]                          @relation("UserInviteAcceptedBy")
  createdStaffChatChannels             StaffChatChannel[]                    @relation("StaffChatChannelCreatedBy")
  staffChatChannelMemberships          StaffChatChannelMember[]              @relation("StaffChatChannelMemberUser")
  addedStaffChatChannelMembers         StaffChatChannelMember[]              @relation("StaffChatChannelMemberAddedBy")
  authoredStaffChatMessages            StaffChatMessage[]                    @relation("StaffChatMessageAuthor")
  staffChatReadReceipts                StaffChatReadReceipt[]
  uploadedStaffAttachments             StaffAttachment[]                     @relation("StaffAttachmentUploadedBy")

  @@index([tenantId])
  @@index([tenantId, role])
  @@index([tenantId, isActive])
  @@index([customRoleId])
}

model UserAccessRole {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users   User[]
  invites UserInvite[]

  @@unique([tenantId, name])
  @@index([tenantId, createdAt])
}

model UserInvite {
  id               String    @id @default(uuid())
  tenantId         String
  email            String?
  fullName         String?
  role             UserRole
  customRoleId     String?
  storeIds         String[]  @default([])
  tokenHash        String    @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  createdByUserId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customRole UserAccessRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  createdBy  User?           @relation("UserInviteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  acceptedBy User?           @relation("UserInviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, acceptedAt])
  @@index([expiresAt])
  @@index([customRoleId])
  @@index([createdByUserId])
  @@index([acceptedByUserId])
}

model UserStoreAccess {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId])
}

model ImportJob {
  id             String   @id @default(uuid())
  tenantId       String
  userId         String?
  type           String
  sourceFileName String?
  status         String
  totalRows      Int      @default(0)
  validRows      Int      @default(0)
  importedRows   Int      @default(0)
  errorsCount    Int      @default(0)
  errorSummary   Json?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId])
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Store {
  id                    String               @id @default(uuid())
  tenantId              String
  name                  String
  address               String?
  isActive              Boolean              @default(true)
  externalProvider      IntegrationProvider?
  externalDomain        String?
  externalClubId        String?
  integrationSourceId   String?
  computerCount         Int?
  computerCountSyncedAt DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  tenant                       Tenant                        @relation(fields: [tenantId], references: [id])
  integrationSource            IntegrationSource?            @relation(fields: [integrationSourceId], references: [id], onDelete: SetNull)
  salesFacts                   SalesFact[]
  guestSessions                GuestSession[]
  guestTransactions            GuestTransaction[]
  guestOperationLogs           GuestOperationLog[]
  guestWorkingShifts           GuestWorkingShift[]
  clubRevenueFacts             ClubRevenueFact[]
  inventorySnapshots           InventorySnapshot[]
  stockMovements               StockMovement[]
  marketingPromoBundleUsages   MarketingPromoBundleUsage[]
  staffTasks                   StaffTask[]
  staffTaskTemplates           StaffTaskTemplate[]
  staffKnowledgeArticles       StaffKnowledgeArticle[]
  staffTrainingCourses         StaffTrainingCourse[]
  staffOnboardingPlans         StaffOnboardingPlan[]
  staffAssessments             StaffAssessment[]
  staffShiftRegulations        StaffShiftRegulation[]
  staffShiftRegulationVersions StaffShiftRegulationVersion[]
  staffChecklistTemplates      StaffChecklistTemplate[]
  staffChecklistRuns           StaffChecklistRun[]
  staffDisciplinePolicies      StaffDisciplinePolicy[]
  staffDisciplineRecords       StaffDisciplineRecord[]
  staffSalarySchemes           StaffSalaryScheme[]
  staffChatChannels            StaffChatChannel[]
  staffChatMessages            StaffChatMessage[]
  userAccesses                 UserStoreAccess[]

  @@unique([tenantId, externalProvider, externalDomain, externalClubId])
  @@index([tenantId])
  @@index([integrationSourceId])
}

model Category {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Supplier {
  id                String   @id @default(uuid())
  tenantId          String
  name              String
  paymentDelayDays  Int?
  minOrderAmount    Decimal?
  orderMultiplicity Int?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id                   String                @id @default(uuid())
  tenantId             String
  categoryId           String?
  supplierId           String?
  article              String
  name                 String
  purchasePrice        Decimal
  salePrice            Decimal
  facing               Int                   @default(1)
  shelfLifeDays        Int?
  isActive             Boolean               @default(true)
  assortmentRole       ProductAssortmentRole @default(OPTIONAL)
  isMandatory          Boolean               @default(false)
  externalProvider     IntegrationProvider?
  externalDomain       String?
  externalProductId    String?
  externalMissingSince DateTime?
  canonicalProductId   String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  tenant             Tenant                @relation(fields: [tenantId], references: [id])
  category           Category?             @relation(fields: [categoryId], references: [id])
  supplier           Supplier?             @relation(fields: [supplierId], references: [id])
  canonicalProduct   CanonicalProduct?     @relation(fields: [canonicalProductId], references: [id], onDelete: SetNull)
  salesFacts         SalesFact[]
  inventorySnapshots InventorySnapshot[]
  stockMovements     StockMovement[]
  oosExclusions      ProductOosExclusion[]

  @@unique([tenantId, article])
  @@unique([tenantId, externalProvider, externalDomain, externalProductId])
  @@index([tenantId])
  @@index([categoryId])
  @@index([supplierId])
  @@index([canonicalProductId])
  @@index([tenantId, externalMissingSince])
  @@index([tenantId, assortmentRole])
  @@index([tenantId, isMandatory])
}

model CanonicalProduct {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  normalizedKey String
  brand         String?
  volumeValue   Int?
  volumeUnit    String?
  flavor        String?
  variant       String?
  packageType   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant                     @relation(fields: [tenantId], references: [id])
  products    Product[]
  suggestions ProductParsingSuggestion[]

  @@unique([tenantId, normalizedKey])
  @@index([tenantId])
}

model ProductParsingRun {
  id               String    @id @default(uuid())
  tenantId         String
  status           String    @default("COMPLETED")
  totalProducts    Int       @default(0)
  suggestionsCount Int       @default(0)
  appliedCount     Int       @default(0)
  rejectedCount    Int       @default(0)
  createdAt        DateTime  @default(now())
  finishedAt       DateTime?

  tenant      Tenant                     @relation(fields: [tenantId], references: [id])
  suggestions ProductParsingSuggestion[]

  @@index([tenantId, createdAt])
}

model ProductParsingSuggestion {
  id                 String                         @id @default(uuid())
  tenantId           String
  runId              String
  canonicalProductId String?
  suggestedName      String
  selectedName       String?
  normalizedKey      String
  confidence         Int
  rationale          Json
  productIds         String[]
  candidateNames     String[]
  status             ProductParsingSuggestionStatus @default(PENDING)
  isUserRejected     Boolean                        @default(false)
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  run              ProductParsingRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  canonicalProduct CanonicalProduct? @relation(fields: [canonicalProductId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([runId])
  @@index([canonicalProductId])
}

model ProductOosExclusion {
  id        String                  @id @default(uuid())
  tenantId  String
  productId String
  type      ProductOosExclusionType
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId])
  @@index([tenantId, type])
  @@index([productId])
}

model RecommendationState {
  id                String               @id @default(uuid())
  tenantId          String
  recommendationKey String
  role              RecommendationRole
  status            RecommendationStatus @default(NEW)
  note              String?
  firstSeenAt       DateTime             @default(now())
  lastSeenAt        DateTime             @default(now())
  statusChangedAt   DateTime             @default(now())
  resolvedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, recommendationKey], map: "recommendation_state_tenant_key_uidx")
  @@index([tenantId, status], map: "recommendation_state_status_idx")
  @@index([tenantId, role], map: "recommendation_state_role_idx")
  @@index([tenantId, lastSeenAt], map: "recommendation_state_last_seen_idx")
}

model ReportDigestScheduleRun {
  id               String    @id @default(uuid())
  tenantId         String
  type             String
  scheduledForDate String
  status           String    @default("RUNNING")
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  sentCount        Int       @default(0)
  errorMessage     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, scheduledForDate], map: "report_digest_schedule_tenant_type_date_uidx")
  @@index([tenantId, status, startedAt], map: "report_digest_schedule_status_started_idx")
}

model SalesFact {
  id                String               @id @default(uuid())
  tenantId          String
  storeId           String
  productId         String
  saleDate          DateTime
  quantity          Decimal
  revenue           Decimal
  cost              Decimal
  externalProvider  IntegrationProvider?
  externalDomain    String?
  externalSaleId    String?
  externalProductId String?
  externalClubId    String?
  externalGuestId   String?
  productNameAtSale String?
  storeNameAtSale   String?
  guestId           String?
  sourcePayloadHash String?
  isCanceled        Boolean              @default(false)
  canceledAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  guest   Guest?  @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalProvider, externalDomain, externalSaleId])
  @@index([tenantId, saleDate])
  @@index([tenantId, isCanceled, saleDate])
  @@index([tenantId, externalGuestId])
  @@index([tenantId, storeId, productId, saleDate])
  @@index([storeId])
  @@index([productId])
  @@index([guestId])
}

model ClubRevenueFact {
  id               String               @id @default(uuid())
  tenantId         String
  storeId          String?
  revenueDate      DateTime
  totalRevenue     Decimal
  externalProvider IntegrationProvider?
  externalDomain   String?
  externalClubId   String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, storeId, revenueDate])
  @@unique([tenantId, externalProvider, externalDomain, externalClubId, revenueDate])
  @@index([tenantId, revenueDate])
  @@index([storeId])
}

model InventorySnapshot {
  id               String               @id @default(uuid())
  tenantId         String
  storeId          String
  productId        String
  snapshotDate     DateTime
  quantity         Decimal
  externalProvider IntegrationProvider?
  externalDomain   String?
  externalClubId   String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, storeId, productId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@index([storeId])
  @@index([productId])
}

model IntegrationCredential {
  id              String              @id @default(uuid())
  tenantId        String
  provider        IntegrationProvider
  name            String
  apiKeyEncrypted String?
  apiKeyEnvVar    String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant  Tenant              @relation(fields: [tenantId], references: [id])
  sources IntegrationSource[]

  @@unique([tenantId, provider, name])
  @@index([tenantId])
}

model IntegrationSource {
  id             String              @id @default(uuid())
  tenantId       String
  credentialId   String
  provider       IntegrationProvider
  name           String
  baseUrl        String
  domain         String
  isActive       Boolean             @default(true)
  lastSyncedAt   DateTime?
  lastSyncedDate DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  credential           IntegrationCredential @relation(fields: [credentialId], references: [id])
  stores               Store[]
  syncJobs             IntegrationSyncJob[]
  guestDataProfileRuns GuestDataProfileRun[]

  @@unique([tenantId, provider, domain])
  @@index([tenantId])
  @@index([credentialId])
  @@index([lastSyncedDate])
}

model IntegrationSyncJob {
  id                  String                 @id @default(uuid())
  tenantId            String
  integrationSourceId String?
  provider            IntegrationProvider
  domain              String
  status              IntegrationSyncStatus
  trigger             IntegrationSyncTrigger @default(MANUAL)
  mode                IntegrationSyncMode    @default(BACKFILL)
  startedAt           DateTime               @default(now())
  finishedAt          DateTime?
  storesCount         Int                    @default(0)
  productsCount       Int                    @default(0)
  inventoryCount      Int                    @default(0)
  salesCount          Int                    @default(0)
  discrepancyCount    Int                    @default(0)
  discrepancyLogPath  String?
  errorMessage        String?

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  integrationSource IntegrationSource? @relation(fields: [integrationSourceId], references: [id], onDelete: SetNull)

  @@index([tenantId, startedAt])
  @@index([integrationSourceId])
  @@index([status])
}

model StockMovement {
  id           String            @id @default(uuid())
  tenantId     String
  storeId      String
  productId    String
  movementDate DateTime
  type         StockMovementType
  quantity     Decimal
  amount       Decimal
  reason       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, storeId, productId, movementDate, type])
  @@index([tenantId, movementDate])
  @@index([storeId])
  @@index([productId])
  @@index([type])
}

