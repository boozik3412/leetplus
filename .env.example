# Historical anti-join recovery is separate from the ordinary bounded latest
# snapshot window and is OFF by default. Enabling SHADOW/LIVE also requires an
# explicitly false kill switch plus an exact tenant. LIVE additionally needs a
# timezone-qualified cutoff and either an exact profile or the explicit
# tenant-wide opt-in. Unknown boolean values fail closed.
GUEST_GAME_PIPELINE_BACKFILL_MODE="OFF"
GUEST_GAME_PIPELINE_BACKFILL_KILL_SWITCH="true"
GUEST_GAME_PIPELINE_BACKFILL_TENANT_ID=""
GUEST_GAME_PIPELINE_BACKFILL_TENANT_SLUG=""
GUEST_GAME_PIPELINE_BACKFILL_PROFILE_ID=""
GUEST_GAME_PIPELINE_BACKFILL_LIVE_NOT_BEFORE=""
GUEST_GAME_PIPELINE_BACKFILL_ALLOW_TENANT_WIDE="false"
# SQL scan window is clamped by the API to 1-90 days; default is 30 days.
GUEST_GAME_PIPELINE_BACKFILL_LOOKBACK_MS="2592000000"
# Изолированный второй боевой слой. Без явного LIVE ничего не выдаёт.
GUEST_GAME_SUPPLEMENTAL_PIPELINE_MODE="OFF"
GUEST_GAME_SUPPLEMENTAL_FACT_TYPES="BALANCE_TOPUP"
GUEST_GAME_SUPPLEMENTAL_PIPELINE_KILL_SWITCH="false"
GUEST_GAME_SUPPLEMENTAL_PIPELINE_INTERVAL_MS="15000"
GUEST_GAME_SUPPLEMENTAL_PIPELINE_BATCH_SIZE="30"
GUEST_GAME_SUPPLEMENTAL_PIPELINE_TENANT_ID=""
GUEST_GAME_SUPPLEMENTAL_PIPELINE_TENANT_SLUG=""
# Sequential LIVE -> ledger fallback. OFF is the safe default.
# LIVE waits for the primary source during GRACE_MS before processing ledger facts.
GUEST_GAME_LEDGER_FALLBACK_MODE="OFF"
GUEST_GAME_LEDGER_FALLBACK_KILL_SWITCH="false"
# Play-time is the only safe default. PRODUCT_PURCHASED requires an explicit
# opt-in after cancellation/return lifecycle reconciliation is verified.
GUEST_GAME_LEDGER_FALLBACK_FACT_TYPES="HOURLY_PLAY_TIME_ACCUMULATED,PACKAGE_OR_SUBSCRIPTION_PLAY_TIME_ACCUMULATED"
GUEST_GAME_LEDGER_FALLBACK_GRACE_MS="60000"
GUEST_GAME_LEDGER_FALLBACK_CLAIM_LEASE_MS="120000"
GUEST_GAME_LEDGER_FALLBACK_INTERVAL_MS="15000"
GUEST_GAME_LEDGER_FALLBACK_BATCH_SIZE="30"
GUEST_GAME_LEDGER_FALLBACK_TENANT_ID=""
GUEST_GAME_LEDGER_FALLBACK_TENANT_SLUG=""
# LIVE is fail-closed and requires an exact tenant, profile, season, Battle Pass
# step and UTC cutoff. Facts before LIVE_NOT_BEFORE are never promoted from
# historical SHADOW receipts. ALLOW_ALL_TENANTS is prohibited in LIVE.
GUEST_GAME_LEDGER_FALLBACK_PROFILE_ID=""
GUEST_GAME_LEDGER_FALLBACK_SEASON_ID=""
GUEST_GAME_LEDGER_FALLBACK_BATTLE_PASS_STEP=""
# Explicitly widens only ACTIVE PLAY_TIME missions with
# LIVE_WITH_LEDGER_FALLBACK to every profile in the configured tenant.
# The Battle Pass remains limited to the exact canary scope above.
GUEST_GAME_LEDGER_FALLBACK_MISSIONS_ALLOW_ALL_PROFILES="false"
GUEST_GAME_LEDGER_FALLBACK_LIVE_NOT_BEFORE=""
GUEST_GAME_LEDGER_FALLBACK_ALLOW_ALL_TENANTS="false"
# Session-start case entitlement recovery. The primary LIVE evaluator always
# gets the first chance; SHADOW/LIVE only use normalized ledger facts after the
# grace window. LIVE is fail-closed without an exact tenant, profile and UTC
# cutoff. This worker creates an opening entitlement, never a random prize.
GUEST_GAME_LOOT_BOX_RECOVERY_MODE="OFF"
GUEST_GAME_LOOT_BOX_RECOVERY_KILL_SWITCH="true"
GUEST_GAME_LOOT_BOX_RECOVERY_TENANT_ID=""
GUEST_GAME_LOOT_BOX_RECOVERY_TENANT_SLUG=""
GUEST_GAME_LOOT_BOX_RECOVERY_PROFILE_ID=""
GUEST_GAME_LOOT_BOX_RECOVERY_LIVE_NOT_BEFORE=""
GUEST_GAME_LOOT_BOX_RECOVERY_ALLOW_ALL_TENANTS="false"
GUEST_GAME_LOOT_BOX_RECOVERY_INTERVAL_MS="15000"
GUEST_GAME_LOOT_BOX_RECOVERY_BATCH_SIZE="30"
GUEST_GAME_LOOT_BOX_RECOVERY_CORRELATION_WINDOW_MS="60000"
GUEST_GAME_LOOT_BOX_RECOVERY_GRACE_MS="60000"
GUEST_GAME_LOOT_BOX_RECOVERY_CLAIM_LEASE_MS="120000"
GUEST_GAME_LOOT_BOX_RECOVERY_RETRY_BATCH_SIZE="30"
GUEST_GAME_LOOT_BOX_RECOVERY_MAX_ATTEMPTS="5"
GUEST_GAME_LOOT_BOX_RECOVERY_LOOKBACK_MS="86400000"
GUEST_GAME_LOOT_BOX_RECOVERY_OVERLAP_BATCH_SIZE="30"
# Durable reward-intent/effect recovery worker. ENABLED controls background
# recovery only; the KILL_SWITCH is the global stop for inline and background
# claims. Background recovery is fail-closed: disabled and unscoped by default.
GUEST_GAME_REWARD_MATERIALIZER_ENABLED="false"
GUEST_GAME_REWARD_MATERIALIZER_KILL_SWITCH="false"
GUEST_GAME_REWARD_MATERIALIZER_TENANT_ID=""
GUEST_GAME_REWARD_MATERIALIZER_TENANT_SLUG=""
GUEST_GAME_REWARD_MATERIALIZER_ALLOW_ALL_TENANTS="false"
GUEST_GAME_REWARD_MATERIALIZER_INTERVAL_MS="15000"
GUEST_GAME_REWARD_MATERIALIZER_BATCH_SIZE="30"
GUEST_GAME_REWARD_MATERIALIZER_CLAIM_LEASE_MS="120000"
GUEST_GAME_REWARD_MATERIALIZER_MAX_ATTEMPTS="5"
