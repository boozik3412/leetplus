generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  BUYER
  ADMIN
}

enum StockMovementType {
  WRITEOFF
  RETURN
}

enum IntegrationProvider {
  LANGAME
}

enum IntegrationSyncStatus {
  SUCCESS
  FAILED
}

enum IntegrationSyncTrigger {
  MANUAL
  AUTO
}

enum IntegrationSyncMode {
  QUICK
  INVENTORY
  CATALOG
  BACKFILL
  FULL
}

enum ProductParsingSuggestionStatus {
  PENDING
  APPLIED
  REJECTED
}

enum ProductOosExclusionType {
  SERVICE
  OOS_EXCLUDED
}

enum GuestCrmStatus {
  NONE
  WATCH
  CONTACT
  INVITED
  LOYAL
  VIP
  PROBLEM
  DO_NOT_CONTACT
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                      User[]
  stores                     Store[]
  suppliers                  Supplier[]
  products                   Product[]
  canonicalProducts          CanonicalProduct[]
  productParsingRuns         ProductParsingRun[]
  productParsingSuggestions  ProductParsingSuggestion[]
  productOosExclusions       ProductOosExclusion[]
  categories                 Category[]
  importJobs                 ImportJob[]
  salesFacts                 SalesFact[]
  clubRevenueFacts           ClubRevenueFact[]
  inventorySnapshots         InventorySnapshot[]
  stockMovements             StockMovement[]
  integrationCredentials     IntegrationCredential[]
  integrationSources         IntegrationSource[]
  integrationSyncJobs        IntegrationSyncJob[]
  guests                     Guest[]
  guestGroups                GuestGroup[]
  guestBalanceSnapshots      GuestBalanceSnapshot[]
  guestBonusBalanceSnapshots GuestBonusBalanceSnapshot[]
  guestSessions              GuestSession[]
  guestLogs                  GuestLog[]
  guestTransactions          GuestTransaction[]
  guestOperationLogs         GuestOperationLog[]
  guestWorkingShifts         GuestWorkingShift[]
  guestDataProfileRuns       GuestDataProfileRun[]
  guestCrmEvents             GuestCrmEvent[]
}

model User {
  id              String    @id @default(uuid())
  tenantId        String
  email           String    @unique
  passwordHash    String
  fullName        String?
  role            UserRole  @default(OWNER)
  isPlatformAdmin Boolean   @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  emailVerificationTokens EmailVerificationToken[]
  importJobs              ImportJob[]
  guestCrmEvents          GuestCrmEvent[]

  @@index([tenantId])
}

model ImportJob {
  id             String   @id @default(uuid())
  tenantId       String
  userId         String?
  type           String
  sourceFileName String?
  status         String
  totalRows      Int      @default(0)
  validRows      Int      @default(0)
  importedRows   Int      @default(0)
  errorsCount    Int      @default(0)
  errorSummary   Json?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId])
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Store {
  id                  String               @id @default(uuid())
  tenantId            String
  name                String
  address             String?
  isActive            Boolean              @default(true)
  externalProvider    IntegrationProvider?
  externalDomain      String?
  externalClubId      String?
  integrationSourceId String?
  computerCount       Int?
  computerCountSyncedAt DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  integrationSource  IntegrationSource?  @relation(fields: [integrationSourceId], references: [id], onDelete: SetNull)
  salesFacts         SalesFact[]
  guestSessions      GuestSession[]
  guestTransactions  GuestTransaction[]
  guestOperationLogs GuestOperationLog[]
  guestWorkingShifts GuestWorkingShift[]
  clubRevenueFacts   ClubRevenueFact[]
  inventorySnapshots InventorySnapshot[]
  stockMovements     StockMovement[]

  @@unique([tenantId, externalProvider, externalDomain, externalClubId])
  @@index([tenantId])
  @@index([integrationSourceId])
}

model Category {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Supplier {
  id                String   @id @default(uuid())
  tenantId          String
  name              String
  paymentDelayDays  Int?
  minOrderAmount    Decimal?
  orderMultiplicity Int?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id                   String               @id @default(uuid())
  tenantId             String
  categoryId           String?
  supplierId           String?
  article              String
  name                 String
  purchasePrice        Decimal
  salePrice            Decimal
  facing               Int                  @default(1)
  shelfLifeDays        Int?
  isActive             Boolean              @default(true)
  externalProvider     IntegrationProvider?
  externalDomain       String?
  externalProductId    String?
  externalMissingSince DateTime?
  canonicalProductId   String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  tenant             Tenant                @relation(fields: [tenantId], references: [id])
  category           Category?             @relation(fields: [categoryId], references: [id])
  supplier           Supplier?             @relation(fields: [supplierId], references: [id])
  canonicalProduct   CanonicalProduct?     @relation(fields: [canonicalProductId], references: [id], onDelete: SetNull)
  salesFacts         SalesFact[]
  inventorySnapshots InventorySnapshot[]
  stockMovements     StockMovement[]
  oosExclusions      ProductOosExclusion[]

  @@unique([tenantId, article])
  @@unique([tenantId, externalProvider, externalDomain, externalProductId])
  @@index([tenantId])
  @@index([categoryId])
  @@index([supplierId])
  @@index([canonicalProductId])
  @@index([tenantId, externalMissingSince])
}

model CanonicalProduct {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  normalizedKey String
  brand         String?
  volumeValue   Int?
  volumeUnit    String?
  flavor        String?
  variant       String?
  packageType   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant                     @relation(fields: [tenantId], references: [id])
  products    Product[]
  suggestions ProductParsingSuggestion[]

  @@unique([tenantId, normalizedKey])
  @@index([tenantId])
}

model ProductParsingRun {
  id               String    @id @default(uuid())
  tenantId         String
  status           String    @default("COMPLETED")
  totalProducts    Int       @default(0)
  suggestionsCount Int       @default(0)
  appliedCount     Int       @default(0)
  rejectedCount    Int       @default(0)
  createdAt        DateTime  @default(now())
  finishedAt       DateTime?

  tenant      Tenant                     @relation(fields: [tenantId], references: [id])
  suggestions ProductParsingSuggestion[]

  @@index([tenantId, createdAt])
}

model ProductParsingSuggestion {
  id                 String                         @id @default(uuid())
  tenantId           String
  runId              String
  canonicalProductId String?
  suggestedName      String
  selectedName       String?
  normalizedKey      String
  confidence         Int
  rationale          Json
  productIds         String[]
  candidateNames     String[]
  status             ProductParsingSuggestionStatus @default(PENDING)
  isUserRejected     Boolean                        @default(false)
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  run              ProductParsingRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  canonicalProduct CanonicalProduct? @relation(fields: [canonicalProductId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([runId])
  @@index([canonicalProductId])
}

model ProductOosExclusion {
  id        String                  @id @default(uuid())
  tenantId  String
  productId String
  type      ProductOosExclusionType
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId])
  @@index([tenantId, type])
  @@index([productId])
}

model SalesFact {
  id                String               @id @default(uuid())
  tenantId          String
  storeId           String
  productId         String
  saleDate          DateTime
  quantity          Decimal
  revenue           Decimal
  cost              Decimal
  externalProvider  IntegrationProvider?
  externalDomain    String?
  externalSaleId    String?
  externalProductId String?
  externalClubId    String?
  externalGuestId   String?
  productNameAtSale String?
  storeNameAtSale   String?
  guestId           String?
  sourcePayloadHash String?
  isCanceled        Boolean              @default(false)
  canceledAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  guest   Guest?  @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalProvider, externalDomain, externalSaleId])
  @@index([tenantId, saleDate])
  @@index([tenantId, isCanceled, saleDate])
  @@index([tenantId, externalGuestId])
  @@index([tenantId, storeId, productId, saleDate])
  @@index([storeId])
  @@index([productId])
  @@index([guestId])
}

model ClubRevenueFact {
  id               String               @id @default(uuid())
  tenantId         String
  storeId          String?
  revenueDate      DateTime
  totalRevenue     Decimal
  externalProvider IntegrationProvider?
  externalDomain   String?
  externalClubId   String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, storeId, revenueDate])
  @@unique([tenantId, externalProvider, externalDomain, externalClubId, revenueDate])
  @@index([tenantId, revenueDate])
  @@index([storeId])
}

model InventorySnapshot {
  id               String               @id @default(uuid())
  tenantId         String
  storeId          String
  productId        String
  snapshotDate     DateTime
  quantity         Decimal
  externalProvider IntegrationProvider?
  externalDomain   String?
  externalClubId   String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, storeId, productId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@index([storeId])
  @@index([productId])
}

model IntegrationCredential {
  id              String              @id @default(uuid())
  tenantId        String
  provider        IntegrationProvider
  name            String
  apiKeyEncrypted String?
  apiKeyEnvVar    String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant  Tenant              @relation(fields: [tenantId], references: [id])
  sources IntegrationSource[]

  @@unique([tenantId, provider, name])
  @@index([tenantId])
}

model IntegrationSource {
  id             String              @id @default(uuid())
  tenantId       String
  credentialId   String
  provider       IntegrationProvider
  name           String
  baseUrl        String
  domain         String
  isActive       Boolean             @default(true)
  lastSyncedAt   DateTime?
  lastSyncedDate DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  credential           IntegrationCredential @relation(fields: [credentialId], references: [id])
  stores               Store[]
  syncJobs             IntegrationSyncJob[]
  guestDataProfileRuns GuestDataProfileRun[]

  @@unique([tenantId, provider, domain])
  @@index([tenantId])
  @@index([credentialId])
  @@index([lastSyncedDate])
}

model IntegrationSyncJob {
  id                  String                 @id @default(uuid())
  tenantId            String
  integrationSourceId String?
  provider            IntegrationProvider
  domain              String
  status              IntegrationSyncStatus
  trigger             IntegrationSyncTrigger @default(MANUAL)
  mode                IntegrationSyncMode    @default(BACKFILL)
  startedAt           DateTime               @default(now())
  finishedAt          DateTime?
  storesCount         Int                    @default(0)
  productsCount       Int                    @default(0)
  inventoryCount      Int                    @default(0)
  salesCount          Int                    @default(0)
  discrepancyCount    Int                    @default(0)
  discrepancyLogPath  String?
  errorMessage        String?

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  integrationSource IntegrationSource? @relation(fields: [integrationSourceId], references: [id], onDelete: SetNull)

  @@index([tenantId, startedAt])
  @@index([integrationSourceId])
  @@index([status])
}

model StockMovement {
  id           String            @id @default(uuid())
  tenantId     String
  storeId      String
  productId    String
  movementDate DateTime
  type         StockMovementType
  quantity     Decimal
  amount       Decimal
  reason       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, storeId, productId, movementDate, type])
  @@index([tenantId, movementDate])
  @@index([storeId])
  @@index([productId])
  @@index([type])
}

model Guest {
  id                      String               @id @default(uuid())
  tenantId                String
  externalProvider        IntegrationProvider?
  externalDomain          String?
  externalGuestId         String
  externalGuestTypeId     String?
  phoneHash               String?
  phoneMasked             String?
  phoneEncrypted          String?
  emailHash               String?
  emailMasked             String?
  fullNameHash            String?
  fullNameMasked          String?
  fullNameEncrypted       String?
  birthYear               Int?
  birthMonth              Int?
  birthDay                Int?
  gender                  String?
  insertedAt              DateTime?
  lastActivityAt          DateTime?
  isVirtual               Boolean              @default(false)
  isTemporary             Boolean              @default(false)
  isDisabled              Boolean              @default(false)
  isSimpleRegistration    Boolean              @default(false)
  isConfirmed             Boolean              @default(false)
  currentCountHours       Decimal?
  isMobileRegistration    Boolean              @default(false)
  identityDocumentPresent Boolean              @default(false)
  bonusProgramNumber      String?
  crmStatus               GuestCrmStatus       @default(NONE)
  crmNote                 String?
  nextAction              String?
  nextContactAt           DateTime?
  crmUpdatedByUserId      String?
  crmUpdatedAt            DateTime?
  sourcePayloadHash       String?
  lastSyncedAt            DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  tenant                Tenant                      @relation(fields: [tenantId], references: [id])
  salesFacts            SalesFact[]
  balanceSnapshots      GuestBalanceSnapshot[]
  bonusBalanceSnapshots GuestBonusBalanceSnapshot[]
  sessions              GuestSession[]
  logs                  GuestLog[]
  transactions          GuestTransaction[]
  workingShifts         GuestWorkingShift[]
  crmEvents             GuestCrmEvent[]

  @@unique([tenantId, externalProvider, externalDomain, externalGuestId])
  @@index([tenantId])
  @@index([tenantId, externalGuestTypeId])
  @@index([tenantId, lastActivityAt])
  @@index([tenantId, crmStatus])
  @@index([tenantId, nextContactAt])
  @@index([tenantId, phoneHash])
  @@index([tenantId, emailHash])
}

model GuestCrmEvent {
  id              String         @id @default(uuid())
  tenantId        String
  guestId         String
  createdByUserId String?
  status          GuestCrmStatus
  note            String?
  nextAction      String?
  nextContactAt   DateTime?
  createdAt       DateTime       @default(now())

  tenant        Tenant @relation(fields: [tenantId], references: [id])
  guest         Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([guestId, createdAt])
  @@index([createdByUserId])
}

model GuestGroup {
  id                String               @id @default(uuid())
  tenantId          String
  externalProvider  IntegrationProvider?
  externalDomain    String?
  externalGroupId   String
  name              String
  percent           Decimal?
  countHoursFrom    Decimal?
  countHoursTo      Decimal?
  bonusBirthday     Decimal?
  sourcePayloadHash String?
  lastSyncedAt      DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, externalProvider, externalDomain, externalGroupId])
  @@index([tenantId])
}

model GuestBalanceSnapshot {
  id                String               @id @default(uuid())
  tenantId          String
  guestId           String?
  externalProvider  IntegrationProvider?
  externalDomain    String?
  externalGuestId   String
  snapshotDate      DateTime
  balance           Decimal
  sourcePayloadHash String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  guest  Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalProvider, externalDomain, externalGuestId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@index([guestId])
}

model GuestBonusBalanceSnapshot {
  id                String               @id @default(uuid())
  tenantId          String
  guestId           String?
  externalProvider  IntegrationProvider?
  externalDomain    String?
  externalGuestId   String
  snapshotDate      DateTime
  bonusBalance      Decimal
  sourcePayloadHash String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  guest  Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalProvider, externalDomain, externalGuestId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@index([guestId])
}

model GuestSession {
  id                String               @id @default(uuid())
  tenantId          String
  guestId           String?
  storeId           String?
  externalProvider  IntegrationProvider?
  externalDomain    String?
  externalSessionId String
  externalGuestId   String?
  externalClubId    String?
  externalUuid      String?
  startedAt         DateTime?
  stoppedAt         DateTime?
  durationMinutes   Int?
  normalStop        Boolean?
  expand            Boolean?
  createByRezerv    Boolean?
  packet            Boolean?
  sourcePayloadHash String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  guest  Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)
  store  Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalProvider, externalDomain, externalSessionId])
  @@index([tenantId, startedAt])
  @@index([tenantId, externalGuestId])
  @@index([guestId])
  @@index([storeId])
}

model GuestLog {
  id                String               @id @default(uuid())
  tenantId          String
  guestId           String?
  externalProvider  IntegrationProvider?
  externalDomain    String?
  sourceKey         String
  externalGuestId   String?
  type              String?
  happenedAt        DateTime?
  sourcePayloadHash String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  guest  Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalProvider, externalDomain, sourceKey])
  @@index([tenantId, happenedAt])
  @@index([tenantId, type])
  @@index([tenantId, externalGuestId])
  @@index([guestId])
}

model GuestTransaction {
  id                    String               @id @default(uuid())
  tenantId              String
  guestId               String?
  storeId               String?
  externalProvider      IntegrationProvider?
  externalDomain        String?
  externalTransactionId String
  externalGuestId       String?
  externalClubId        String?
  type                  String?
  happenedAt            DateTime?
  updatedAtExternal     DateTime?
  amount                Decimal?
  balance               Decimal?
  bonusBalance          Decimal?
  sourcePayloadHash     String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  guest  Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)
  store  Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalProvider, externalDomain, externalTransactionId])
  @@index([tenantId, happenedAt])
  @@index([tenantId, type])
  @@index([tenantId, externalGuestId])
  @@index([guestId])
  @@index([storeId])
}

model GuestOperationLog {
  id                String               @id @default(uuid())
  tenantId          String
  storeId           String?
  externalProvider  IntegrationProvider?
  externalDomain    String?
  sourceKey         String
  externalClubId    String?
  type              String?
  happenedAt        DateTime?
  amount            Decimal?
  sourcePayloadHash String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalProvider, externalDomain, sourceKey])
  @@index([tenantId, happenedAt])
  @@index([tenantId, type])
  @@index([storeId])
}

model GuestWorkingShift {
  id                String               @id @default(uuid())
  tenantId          String
  guestId           String?
  storeId           String?
  externalProvider  IntegrationProvider?
  externalDomain    String?
  externalShiftId   String
  externalUserId    String?
  externalClubId    String?
  startedAt         DateTime?
  stoppedAt         DateTime?
  durationMinutes   Int?
  cashStart         Decimal?
  cashAmount        Decimal?
  cashlessAmount    Decimal?
  refundsCash       Decimal?
  refundsCashless   Decimal?
  mobilePay         Decimal?
  yandexPay         Decimal?
  incassAmount      Decimal?
  middleCheck       Decimal?
  message           String?
  sourcePayloadHash String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  guest  Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)
  store  Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalProvider, externalDomain, externalShiftId])
  @@index([tenantId, startedAt])
  @@index([tenantId, externalUserId])
  @@index([guestId])
  @@index([storeId])
}

model GuestDataProfileRun {
  id                  String              @id @default(uuid())
  tenantId            String
  integrationSourceId String?
  provider            IntegrationProvider
  domain              String
  status              String              @default("RUNNING")
  dateFrom            DateTime?
  dateTo              DateTime?
  startedAt           DateTime            @default(now())
  finishedAt          DateTime?
  guestsCount         Int                 @default(0)
  sessionsCount       Int                 @default(0)
  transactionsCount   Int                 @default(0)
  productSalesLinked  Int                 @default(0)
  profile             Json?
  errorMessage        String?

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  integrationSource IntegrationSource? @relation(fields: [integrationSourceId], references: [id], onDelete: SetNull)

  @@index([tenantId, startedAt])
  @@index([integrationSourceId])
  @@index([status])
}
