  updatedAt    DateTime @updatedAt

  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel      StaffChatChannel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorUser   User?                  @relation("StaffChatMessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  store        Store?                 @relation(fields: [storeId], references: [id], onDelete: SetNull)
  readReceipts StaffChatReadReceipt[]

  @@index([tenantId, createdAt], map: "staff_chat_message_tenant_created_idx")
  @@index([tenantId, isPinned, createdAt], map: "staff_chat_message_pinned_idx")
  @@index([channelId, createdAt], map: "staff_chat_message_channel_created_idx")
  @@index([authorUserId], map: "staff_chat_message_author_idx")
  @@index([storeId], map: "staff_chat_message_store_idx")
}

model StaffChatReadReceipt {
  id        String   @id @default(uuid())
  tenantId  String
  channelId String
  messageId String
  userId    String
  readAt    DateTime @default(now())

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel StaffChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message StaffChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId], map: "staff_chat_read_receipt_message_user_unique")
  @@index([tenantId, userId, readAt], map: "staff_chat_read_receipt_user_idx")
  @@index([channelId, userId], map: "staff_chat_read_receipt_channel_user_idx")
}

model GuestSavedFilter {
  id              String    @id @default(uuid())
  tenantId        String
  createdByUserId String?
  report          String    @default("guest_report")
  name            String
  description     String?
  filters         Json
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id])
  createdByUser User?  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, report, createdAt], map: "guest_saved_filter_report_idx")
  @@index([createdByUserId], map: "guest_saved_filter_user_idx")
}

model GuestAudience {
  id              String   @id @default(uuid())
  tenantId        String
  createdByUserId String?
  name            String
  description     String?
  filters         Json
  guestsCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant             Tenant                 @relation(fields: [tenantId], references: [id])
  createdByUser      User?                  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  members            GuestAudienceMember[]
  crmTasks           GuestCrmTask[]
  crmContactEvents   GuestCrmContactEvent[]
  marketingCampaigns MarketingCampaign[]

  @@index([tenantId, createdAt], map: "guest_audience_tenant_created_idx")
  @@index([createdByUserId], map: "guest_audience_user_idx")
}

model GuestAudienceMember {
  id              String   @id @default(uuid())
  tenantId        String
  audienceId      String
  guestId         String?
  externalDomain  String   @default("")
  externalGuestId String
  createdAt       DateTime @default(now())

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  audience GuestAudience @relation(fields: [audienceId], references: [id], onDelete: Cascade)
  guest    Guest?        @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@unique([audienceId, externalDomain, externalGuestId], map: "guest_audience_member_unique")
  @@index([tenantId, audienceId], map: "guest_audience_member_audience_idx")
  @@index([guestId], map: "guest_audience_member_guest_idx")
}

model GuestDataProfileRun {
  id                  String              @id @default(uuid())
  tenantId            String
  integrationSourceId String?
  provider            IntegrationProvider
  domain              String
  status              String              @default("RUNNING")
  dateFrom            DateTime?
  dateTo              DateTime?
  startedAt           DateTime            @default(now())
  finishedAt          DateTime?
  guestsCount         Int                 @default(0)
  sessionsCount       Int                 @default(0)
  transactionsCount   Int                 @default(0)
  productSalesLinked  Int                 @default(0)
  profile             Json?
  errorMessage        String?

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  integrationSource IntegrationSource? @relation(fields: [integrationSourceId], references: [id], onDelete: SetNull)

  @@index([tenantId, startedAt])
  @@index([integrationSourceId])
  @@index([status])
}
