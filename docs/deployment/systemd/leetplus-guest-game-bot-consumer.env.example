# Copy to /etc/leetplus/guest-game-bot-consumer.env on VDS.
# Keep real tokens only on the server.

GUEST_GAME_BOT_CONSUMER_API_URL=https://api.leetplus.ru
GUEST_GAME_BOT_CONSUMER_SYNC_TOKEN=

# Fill one tenant scope. Slug is usually easier to read in ops runbooks.
GUEST_GAME_BOT_CONSUMER_TENANT_SLUG=
# GUEST_GAME_BOT_CONSUMER_TENANT_ID=

# Keep TELEGRAM until MAX has a confirmed provider endpoint and canary plan.
GUEST_GAME_BOT_CONSUMER_CHANNELS=TELEGRAM
GUEST_GAME_BOT_CONSUMER_LIMIT=10
GUEST_GAME_BOT_CONSUMER_DRY_RUN=true

# systemd timer controls cadence; this CLI run should exit after one tick.
GUEST_GAME_BOT_CONSUMER_INTERVAL_MS=
GUEST_GAME_BOT_CONSUMER_MAX_TICKS=1
GUEST_GAME_BOT_CONSUMER_REQUEST_TIMEOUT_MS=15000

GUEST_GAME_BOT_CONSUMER_TELEGRAM_BOT_TOKEN=
# Default direct Bot API. On the non-RF edge VDS this can point to an internal
# Bot API gateway/proxy with the same /bot<TOKEN>/sendMessage path.
GUEST_GAME_BOT_CONSUMER_TELEGRAM_API_BASE_URL=https://api.telegram.org

# Optional generic MAX provider. Leave empty until the provider endpoint/token
# contract is confirmed; first live MAX run must use LIMIT=1.
GUEST_GAME_BOT_CONSUMER_MAX_DELIVERY_ENDPOINT=
GUEST_GAME_BOT_CONSUMER_MAX_BOT_TOKEN=
