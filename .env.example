# Игровой журнал: ежедневный retention запускается в безопасном dry-run.
# Для реального удаления нужны одновременно global live-флаг и tenant policy liveCleanupEnabled=true.
GUEST_GAME_RETENTION_SCHEDULER_ENABLED=true
GUEST_GAME_RETENTION_LIVE_ENABLED=false
GUEST_GAME_RETENTION_INTERVAL_MS=86400000
GUEST_GAME_RETENTION_BATCH_SIZE=1000
GUEST_GAME_RETENTION_MAX_BATCHES=20

# Игровой журнал: quality snapshots и алерты, без влияния на боевые решения.
GUEST_GAME_MONITORING_ENABLED=true
